      "slug": "chiasm",
      "group": "literary",
      "definition": "Symmetrical A-B-C-...-C'-B'-A' pattern with rhetorical weight at the center pivot.",
      "examples": [
        "Genesis 17 (covenant renewal centered on the name change)",
        "Genesis 6:10-9:19 (Flood macro-chiasm, ark afloat at center)",
        "Mark's gospel (Peter's confession at 8:29 as hinge)",
        "Leviticus (Day of Atonement chapter 16 as book center)",
        "Matthew 23 (seven woes in concentric structure)"
      ],
      "suggested_edges": [
        {"kind": "centered_on", "from": "chiasm", "to": "verse|seed"},
        {"kind": "mirrors", "from": "verse", "to": "verse"},
        {"kind": "contains_chiasm", "from": "pericope", "to": "chiasm"}
      ]
    },
    {
      "slug": "inclusio",

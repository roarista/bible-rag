# Bible RAG environment configuration
# Copy this to .env and fill in your values. .env is gitignored.

# OpenAI API key for embeddings (text-embedding-3-large).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API key for the contestation / discovery agent layer.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# (Optional) Path to your Obsidian vault folder containing seeds.
# Defaults to the path hardcoded in bible_rag/__init__.py.
# BIBLE_RAG_VAULT_PATH=/path/to/Obsidian/Brain/01-Projects/Bible-RAG
